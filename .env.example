# OpenClaw Environment Variables
# 複製呢個檔案到 ~/.openclaw/.env 然後填入你嘅 API keys
# cp .env.example ~/.openclaw/.env && chmod 600 ~/.openclaw/.env

# === 必要 ===
OPENCLAW_GATEWAY_TOKEN=          # 自訂任意字串，用於 Gateway 認證
TELEGRAM_BOT_TOKEN=              # 從 @BotFather 取得

# === NVIDIA NIM（免費 tier）===
# 申請：https://build.nvidia.com
NVIDIA_INTEGRATE_API_KEY=        # MiniMax M2.1
NVIDIA_DEEPSEEK_AI_API_KEY=      # DeepSeek V3.2
NVIDIA_QWEN_API_KEY=             # Qwen 3.5
NVIDIA_Z_AI_API_KEY=             # GLM5

# === Jina（memory-lancedb-pro plugin 需要）===
# 申請：https://jina.ai
JINA_API_KEY=                    # Embedding + Reranker

# === 可選 ===
TAVILY_API_KEY=                  # https://tavily.com（Web search skill 用）
