{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillRegistry",
  "description": "Global skill registry structure",
  "type": "object",
  "required": ["skills", "tags"],
  "properties": {
    "skills": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "author": { "type": "string" },
          "created": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "tags": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    }
  }
}
